{
  "name": "intercal64",
  "displayName": "INTERCAL-64",
  "description": "Syntax highlighting and debugger for INTERCAL-64.",
  "version": "2.0.0",
  "publisher": "jawhitti",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onDebugResolve:intercal"
  ],
  "contributes": {
    "breakpoints": [
      { "language": "intercal" }
    ],
    "languages": [
      {
        "id": "intercal",
        "aliases": [
          "intercal64",
          "intercal"
        ],
        "extensions": [
          ".i",
          ".ic64"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "intercal",
        "scopeName": "source.intercal",
        "path": "./syntaxes/schrodie.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "keyword.operator.quantum.bra.intercal",
            "settings": {
              "foreground": "#FF3333",
              "fontStyle": "bold"
            }
          }
        ]
      }
    },
    "snippets": [
      {
        "language": "intercal",
        "path": "./snippets/schrodie.json"
      }
    ],
    "configuration": {
      "title": "INTERCAL-64",
      "properties": {
        "intercal.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Path to the project root (containing intercal64.dap/, churn/, etc.). Auto-detected from workspace if empty."
        }
      }
    },
    "debuggers": [
      {
        "type": "intercal",
        "label": "INTERCAL-64 debugger",
        "languages": [
          "intercal"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .i or .ic64 source file to debug",
                "default": "${file}"
              },
              "compiler": {
                "type": "string",
                "description": "Path to the churn compiler project",
                "default": ""
              },
              "syslib": {
                "type": "string",
                "description": "Path to syslib64.dll",
                "default": ""
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "intercal",
            "request": "launch",
            "name": "Debug INTERCAL-64 program",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "INTERCAL-64: Launch",
            "description": "Launch and debug an INTERCAL-64 program",
            "body": {
              "type": "intercal",
              "request": "launch",
              "name": "Debug INTERCAL-64 program",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ]
  }
}
