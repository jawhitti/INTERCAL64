	DO :1 <- :3
	PLEASE DO :2 <- .5
	DO (1500) NEXT
	DO .3 <- :3 ~ '#65280$#65280'
	DO :5 <- ::10 ~ ####18446744069414584320
	PLEASE DO :6 <- ::31 ~ ####18446744069414584320
	DO :1 <- :5
	DO :2 <- :6
	DO .5 <- '?":1~#65535"$":2~#65535"'~'#0$#65535'
	PLEASE DO .6 <- '?":1~'#65280$#65280'"$":2~'#65280$#65280'"'~'#0$#65535'
	DO .5 <- 'V.5$.6'~'#0$#65535'
	DO .5 <- "?'.5~.5'$#1"~#3
	DO STASH .3
	PLEASE DO :5 <- ::10 ~ ##4294967295
	DO :6 <- ::31 ~ ##4294967295
	DO .6 <- :5 ~ #65535
	DO .6 <- '?.6$#65535'~'#0$#65535'
	PLEASE DO .7 <- :5 ~ '#65280$#65280'
	DO .7 <- '?.7$#65535'~'#0$#65535'
	DO :1 <- :6 ~ #65535
	DO :2 <- .6
	PLEASE DO (1500) NEXT
	DO :1 <- :3
	DO :2 <- #1
	DO (1500) NEXT
	PLEASE DO .6 <- :3 ~ '#65280$#65280'
	DO :1 <- :6 ~ '#65280$#65280'
	DO :2 <- .7
	DO (1500) NEXT
	PLEASE DO :1 <- :3
	DO :2 <- .6
	DO (1500) NEXT
	DO .6 <- :3 ~ '#65280$#65280'
	PLEASE DO RETRIEVE .3
	DO REINSTATE (8139)
	DO (8138) NEXT
	DO NOTE IN RANGE - OUTPUT
	PLEASE READ OUT ::10
	DO (8150) NEXT
(8138) DO (8139) NEXT
	DO ABSTAIN FROM (8139)
(8139) DO RESUME .5
	DO FORGET #1
	PLEASE DO .3 <- .6
	DO .3 <- "?'.3~.3'$#1"~#3
	DO NOTE .3 = 1 IF ::10 > ::31, 2 IF <=
	DO REINSTATE (8149)
	PLEASE DO (8148) NEXT
	DO NOTE ::10 <= ::31, IN RANGE - OUTPUT
	PLEASE READ OUT ::10

(8148) DO (8149) NEXT
