	DO NOTE SHARED SECRET WITH EVE INTERCEPTION
	DO .1 <- #42
	DO []1 <- .1
	PLEASE DO []2 <- .1
	DO ENTANGLE []1 + []2
	DO NOTE EVE INTERCEPTS BOBS BOX AND COLLAPSES IT
	DO ::1 <- []2
	DO READ OUT ::1
	DO NOTE EVE CREATES A FORGERY FOR BOB
	PLEASE DO []2 <- .1
	DO NOTE ALICE OPENS HER BOX ALREADY COLLAPSED
	DO ::2 <- []1
	DO NOTE BOB OPENS EVES FORGERY WHICH IS INDEPENDENT
	PLEASE DO ::3 <- []2
	DO READ OUT ::2
	PLEASE DO READ OUT ::3
	DO GIVE UP
