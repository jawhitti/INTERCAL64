DO NOTE QUANTUM N-WAY NEXT
DO []1 <- .1 <- #1
DO []2 <- .2 <- #2
DO []3 <- .3 <- #3
PLEASE DO ENTANGLE []1 + []2 + []3
DO ⟨1|ψ⟩ (100) ⟨2|ψ⟩ (200) ⟨3|ψ⟩ (300) NEXT
DO GIVE UP
(100) DO FORGET #1
PLEASE DO READ OUT .1
DO GIVE UP
(200) DO FORGET #1
DO READ OUT .2
PLEASE GIVE UP
(300) DO FORGET #1
DO READ OUT .3
DO GIVE UP
