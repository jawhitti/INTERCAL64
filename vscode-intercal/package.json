{
  "name": "schrodie",
  "displayName": "schrodie",
  "description": "Syntax highlighting and debugger for schrodie, a quantum programming language.",
  "version": "1.5.0",
  "publisher": "jawhitti",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onDebugResolve:intercal"
  ],
  "contributes": {
    "breakpoints": [
      { "language": "intercal" }
    ],
    "languages": [
      {
        "id": "intercal",
        "aliases": [
          "schrodie",
          "intercal"
        ],
        "extensions": [
          ".i",
          ".schrodie"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "intercal",
        "scopeName": "source.intercal",
        "path": "./syntaxes/intercal.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "keyword.operator.quantum.bra.intercal",
            "settings": {
              "foreground": "#FF3333",
              "fontStyle": "bold"
            }
          }
        ]
      }
    },
    "snippets": [
      {
        "language": "intercal",
        "path": "./snippets/intercal.json"
      }
    ],
    "configuration": {
      "title": "schrodie",
      "properties": {
        "intercal.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Path to the schrodie project root (containing intercal.dap/, cringe/, etc.). Auto-detected from workspace if empty."
        }
      }
    },
    "debuggers": [
      {
        "type": "intercal",
        "label": "schrodie debugger",
        "languages": [
          "intercal"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .i source file to debug",
                "default": "${file}"
              },
              "compiler": {
                "type": "string",
                "description": "Path to the schrodie compiler project",
                "default": ""
              },
              "syslib": {
                "type": "string",
                "description": "Path to syslib64.dll",
                "default": ""
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "intercal",
            "request": "launch",
            "name": "Debug schrodie program",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "schrodie: Launch",
            "description": "Launch and debug a schrodie program",
            "body": {
              "type": "intercal",
              "request": "launch",
              "name": "Debug schrodie program",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ]
  }
}
