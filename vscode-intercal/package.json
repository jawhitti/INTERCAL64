{
  "name": "intercal",
  "displayName": "INTERCAL",
  "description": "Syntax highlighting and debugger for INTERCAL, the Computer Language with No Pronounceable Acronym. Includes quantum cat box support.",
  "version": "0.2.0",
  "publisher": "jawhitti",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onDebugResolve:intercal"
  ],
  "contributes": {
    "languages": [
      {
        "id": "intercal",
        "aliases": [
          "INTERCAL",
          "intercal"
        ],
        "extensions": [
          ".i"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "intercal",
        "scopeName": "source.intercal",
        "path": "./syntaxes/intercal.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "intercal",
        "label": "INTERCAL Debugger",
        "languages": [
          "intercal"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .i source file to debug",
                "default": "${file}"
              },
              "compiler": {
                "type": "string",
                "description": "Path to the cringe compiler project (cringe.csproj)",
                "default": ""
              },
              "syslib": {
                "type": "string",
                "description": "Path to syslib64.dll",
                "default": ""
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "intercal",
            "request": "launch",
            "name": "Debug INTERCAL Program",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "INTERCAL: Launch",
            "description": "Launch and debug an INTERCAL program",
            "body": {
              "type": "intercal",
              "request": "launch",
              "name": "Debug INTERCAL Program",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ]
  }
}
